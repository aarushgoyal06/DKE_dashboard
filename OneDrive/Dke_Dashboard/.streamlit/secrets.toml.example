# Copy these settings into your Streamlit Cloud app secrets
# (App settings → Secrets) so tasks persist across devices/instances.
#
# 1. Create a free database at https://turso.tech
# 2. Run: turso db tokens create <your-db-name>
# 3. Paste the values below

[turso]
database_url = "libsql://your-database-name-your-org.turso.io"
auth_token = "your-turso-auth-token"
